# Build artifacts
/bin/
/dist/

# Chrome extension: npm deps and everything the build regenerates
# (public/url-trace.wasm + wasm_exec.js come from `npm run build:wasm`)
extension/node_modules/
extension/dist/
extension/public/url-trace.wasm
extension/public/wasm_exec.js
extension/package/

# Test & coverage
*.test
coverage.out
coverage.html

# Real capture/policy data — may contain internal URLs; only examples/ ships
*.har
!examples/*.har
result*.json
policy*.json

# Real SQL export mappings reveal internal schemas/IDs; only the example ships
sqlexport-config*.json
!examples/sqlexport-config.example.json

# IDE / OS
.idea/
.vscode/
.DS_Store
.venv/
.claude/