{
  "manifest_version": 3,
  "name": "url-trace Capture",
  "version": "0.1.0",
  "description": "Passively observes an app's real network requests while you use it, and turns them into url-trace's audit-friendly whitelist records — no cookie injection, no duplicate-login session expiry.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "dist/background.js"
  },
  "permissions": ["webRequest", "storage", "downloads"],
  "optional_host_permissions": ["<all_urls>"],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "minimum_chrome_version": "116"
}
